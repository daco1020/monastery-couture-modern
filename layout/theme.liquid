{%- capture avada-seo-original -%}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
  <!-- MANAGED BY LOCATION REDIRECT APP. DO NOT DELETE -->
  {% if content_for_header contains 'adminBarInjector' %}
  {% elsif content_for_header contains 'previewBarInjector' %}
  {% elsif content_for_header contains 'Shopify.designMode = true' %}
  {% elsif content_for_header contains '.shopifypreview.com' %}
  {% else %}
  <meta name="referrer" content="no-referrer-when-downgrade">
  <script src="https://{{ request.host }}/apps/locate?_p={{ request.path }}"></script>
  {% endif %}
  <!-- END LOCATION REDIRECT APP -->

 <!-- Google Tag Manager -->
<script>
window.dataLayer = window.dataLayer || [];
</script> 
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-WZ5QLLF');</script>
<!-- End Google Tag Manager -->
	<!-- Added by AVADA SEO Suite -->
	{% include 'avada-seo' %}
	<!-- /Added by AVADA SEO Suite -->
    
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    {% render 'meta-tags' %}
    <link rel="canonical" href="{{ canonical_url }}">
    <meta name="viewport" content="width=device-width,initial-scale=1,shrink-to-fit=no">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    {{ 'base.css' | asset_url | stylesheet_tag: preload: true }}
    <link rel="preload" href="{{ 'app.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
    {%- if settings.favicon != blank %}
      <link rel="shortcut icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
      <link rel="apple-touch-icon-precomposed" type="image/png" sizes="152x152" href="{{ settings.favicon | image_url: width: 152 }}">
    {% endif -%}
    {%- if settings.custom_css != blank -%}
      {% style %}
        {{ settings.custom_css }}
      {% endstyle %}
    {%- endif -%}
    <!-- Header hook for plugins -->
    {{ content_for_header }}
    {{ settings.heading_font | asset_url | stylesheet_tag: preload: true }}
    {{ 'modern.css' | asset_url | stylesheet_tag }}
  
{% render 'gsf-conversion-pixels' %}
</head>

  <body class="relative font-display w-full m-0 p-0 text-monastery-black overflow-x-hidden bg-slate-50">
    <a class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:bg-white focus:text-black focus:p-4 focus:shadow-lg" href="#main-content">
      Saltar al contenido
    </a>
    <!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WZ5QLLF"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
    <div id="root" class="relative overlay-hidden h-full min-h-screen flex flex-col">
      {%- if template == 'index' -%}
        <h1 class="sr-only">{{ shop.name }}</h1>
      {%- endif -%}
      {% section 'announcements-bar' %}
      <main id="main-content" role="main" class="relative block grow shrink basis-0">
        {{ content_for_layout }}
      </main>
      {% section 'footer' %}
    </div>

    <div
      data-loader
      class="flex items-center justify-center fixed inset-0 pointer-events-none z-[9998] bg-monastery-black/80 opacity-0 invisible ease-in-out duration-150"
    >
      <span class="modern-loader"></span>
    </div>
    {% render 'cart-sidebar' %}
    {% render 'search-sidebar' %}
    <script src="{{ 'app.js' | asset_url }}" defer></script>
    <script>
      // Modern UX Enhancements
      document.addEventListener('DOMContentLoaded', () => {
        // Header Scroll Effect
        const header = document.querySelector('.site-header');
        if (header) {
          window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
              header.classList.add('is-scrolled');
            } else {
              header.classList.remove('is-scrolled');
            }
          });
        }

        // Reveal Animations
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        }, observerOptions);

        document.querySelectorAll('[data-animate]').forEach(el => {
          revealObserver.observe(el);
        });

        // Sticky ATC Visibility
        const mainAtc = document.querySelector('button[name="add"]');
        const stickyAtc = document.querySelector('[data-sticky-atc]');
        if (mainAtc && stickyAtc) {
          const atcObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                stickyAtc.classList.add('translate-y-full');
              } else {
                // Only show if we've scrolled past it downwards
                if (window.scrollY > entry.boundingClientRect.top + window.scrollY) {
                  stickyAtc.classList.remove('translate-y-full');
                }
              }
            });
          }, { threshold: 0 });
          atcObserver.observe(mainAtc);
        }
      });
    </script>
  </body>
</html>

{%- endcapture avada-seo-original -%}
{%- capture avada-seo-minified -%}
{%- include 'avada-seo-minifier', content: avada-seo-original -%}
{%- endcapture -%}
{%- if avada-seo-minified contains 'Liquid error' -%}
{{ avada-seo-original }}
{%- else -%}
{{ avada-seo-minified }}
{%- endif -%}
