<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    {% render 'meta-tags' %}
    <link rel="canonical" href="{{ canonical_url }}">
    <meta name="viewport" content="width=device-width,initial-scale=1,shrink-to-fit=no">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    {{ 'base.css' | asset_url | stylesheet_tag: preload: true }}
    <link rel="preload" href="{{ 'app.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
    {%- if settings.favicon != blank %}
      <link rel="shortcut icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
      <link rel="apple-touch-icon-precomposed" type="image/png" sizes="152x152" href="{{ settings.favicon | image_url: width: 152 }}">
    {% endif -%}
    {%- if settings.custom_css != blank -%}
      {% style %}
        {{ settings.custom_css }}
      {% endstyle %}
    {%- endif -%}
    <!-- Header hook for plugins -->
    {{ content_for_header }}
    {{ settings.heading_font | asset_url | stylesheet_tag: preload: true }}
  </head>
  <body
    data-collection
    data-collection-handle="{{ collection.handle }}"
    class="relative font-display w-full m-0 p-0 text-monastery-black overflow-x-hidden bg-slate-50"
  >
    <div id="root" class="relative overlay-hidden h-full min-h-screen flex flex-col">
      <main role="main" class="block grow shrink basis-0">
        {{ content_for_layout }}
      </main>
    </div>

    <div
      data-loader
      class="flex items-center justify-center fixed inset-0 pointer-events-none z-[9998] bg-monastery-black/80 opacity-0 ease-in-out duration-150"
    >
      {% render 'loader-icon', classNames: 'w-20 h-20', color: 'white' %}
    </div>
    {% render 'cart-sidebar' %}
    {% render 'search-sidebar' %}
    {% render 'filters-sidebar' %}

    <script src="{{ 'app.js' | asset_url }}" defer></script>
  </body>
</html>
