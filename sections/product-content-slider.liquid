<div data-component="look-book-slider" class="relative w-full flex flex-col {{ section.settings.image_position }}">
  {% if section.blocks.size > 0 %}
    <div class="order-1 p-5 md:w-1/2 md:order-none lg:p-10">
      <div class="flex justify-center items-center h-full">
        <div class="w-full md:max-w-[60%]">
          <!-- Slider main container -->
          <div class="swiper relative group" data-product-lookbook-slider>
            <!-- Additional required wrapper -->
            <div class="swiper-wrapper">
              <!-- Slides -->
              {% for block in section.blocks %}
                {%- if block.settings.product != blank -%}
                  <div class="swiper-slide">
                    {% render 'single-product', product: block.settings.product, layout: 'slide' %}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>

            <button
              class="swiper-button-prev absolute top-1/3 left-1 z-10 bg-monastery-black p-1 md:opacity-0 group-hover:[&:not(.swiper-button-disabled)]:opacity-100 ease-in-out duration-150"
              aria-label="Go previous"
            >
              {% render 'chevron-left', classNames: 'w-5 h-5 text-white' %}
            </button>
            <button
              class="swiper-button-next absolute top-1/3 right-1 z-10 bg-monastery-black p-1 md:opacity-0 group-hover:[&:not(.swiper-button-disabled)]:opacity-100 ease-in-out duration-150"
              aria-label="Go next"
            >
              {% render 'chevron-right', classNames: 'w-5 h-5 text-white' %}
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="relative block overflow-hidden md:w-1/2">
      {% if section.settings.image %}
        <figure
          class="overlay h-full after:content-[''] after:absolute after:pointer-events-none after:inset-0 after:bg-black"
          style="background: {{ section.settings.background }} ;--overlay-opacity: {{ section.settings.overlay }}"
        >
          {{
            section.settings.image.src
            | image_url: width: 1000
            | image_tag: loading: 'lazy', alt: section.settings.image.alt, class: 'block w-full h-full object-contain aspect-square'
          }}
        </figure>
      {% endif %}

      <div>
        {% for block in section.blocks %}
          {%- if block.settings.product != blank -%}
            <button
              data-product-lookbook-button
              data-index="{{ forloop.index }}"
              class="absolute h-5 w-5"
              aria-label="Go to product"
              style="top: {{ block.settings.p-y }}%; left: {{ block.settings.p-x }}%"
            >
              <span
                class="{% if forloop.index == 1 %}animate-ping{% endif %} absolute inline-flex h-full w-full rounded-full bg-black opacity-75 pointer-events-none"
              ></span>
              <span class="relative inline-flex rounded-full bg-black h-5 w-5 pointer-events-none"></span>
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Producto (LookBook)",
  "tag": "section",
  "class": "container",
  "max_blocks": 4,
  "blocks": [
    {
      "name": "Producto",
      "type": "product_column",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Elige un producto"
        },
        {
          "type": "range",
          "id": "p-y",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Elige la posición vertical del punto en la imagen",
          "default": 16
        },
        {
          "type": "range",
          "id": "p-x",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Elige la posición horizontal del punto en la imagen",
          "default": 16
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Elige la imagen"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Elige la posición de la imagen",
      "options": [
        {
          "value": "md:flex-row-reverse",
          "label": "Izquierda"
        },
        {
          "value": "md:flex-row",
          "label": "Derecha"
        }
      ],
      "default": "md:flex-row"
    },
    {
      "type": "color_background",
      "id": "background",
      "label": "Elige un color de fondo",
      "default": "linear-gradient(#acacac, #bebebe)"
    },
    {
      "id": "overlay",
      "type": "range",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay opacity",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Product lookbook"
    }
  ]
}
{% endschema %}
