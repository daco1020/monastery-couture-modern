{%- assign relatedLooks = collection.metafields.custom.related.value -%}

<div data-component="look-book">
  <div class="flex items-start flex-wrap" data-look-book-parallax>
    <div class="basis-full relative lg:sticky lg:basis-1/2 lg:top-0 xl:basis-3/7" data-look-book-parallax-image>
      <figure class="block overflow-hidden">
        <img
          src="{{ collection.featured_image | image_url: width: 2400 }}"
          alt="{{ collection.title }}"
          loading="lazy"
          class="block w-full"
        >
      </figure>

      {% comment %} Points {% endcomment %}
      {% if collection.metafields.custom.coordinates.value %}
        {% for item in collection.metafields.custom.coordinates.value %}
          {% assign coordinates = item | split: "," %}

          <a
            data-index="{{ forloop.index }}"
            href="#Product_{{ forloop.index }}"
            class="absolute h-5 w-5"
            style="top: {{ coordinates[0] }}%; left: {{ coordinates[1] }}%"
            data-look-book-anchor
          >
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-monastery-black opacity-75 pointer-events-none"
            ></span>
            <span class="relative inline-flex rounded-full bg-monastery-black h-5 w-5 pointer-events-none"></span>
          </a>
        {% endfor %}
      {% endif %}
    </div>

    <div class="basis-full lg:basis-1/2 xl:basis-4/7">
      <div class="container py-10 lg:py-40 lg:max-w-md lg:mx-auto xl:max-w-xl">
        <div data-look-book-parallax-content>
          <div class="flex w-full justify-between items-center pb-2 mb-5 border-b border-b-slate-200">
            <div class="text-left max-w-[60%]">
              <h1 class="text-xl font-bold  md:text-2xl">
                {{ collection.title }}
              </h1>
            </div>
            <div class="leading-none text-right">
              <button type="button" class="btn transparent text-xs font-bold" onclick="javascript:history.back()">
                <span class="flex items-center">
                  {% render 'chevron-left', classNames: 'w-3 h-3 mr-1 md:mr-2' %}
                  {{ 'lookbook.go_back' | t }}
                </span>
              </button>
            </div>
          </div>

          {% if collection.description != blank %}
            <div class="rich-text mt-5">
              {{ collection.description }}
            </div>
          {% endif %}

          {% if collection.products.count %}
            <div class="mt-10">
              {% for product in collection.products %}
                {%- if product != blank -%}
                  <div id="Product_{{ forloop.index }}" class="pt-10 lg:pt-15">
                    {% render 'single-product', product: product, layout: 'grid' %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% if relatedLooks %}
  <div class="container py-10" data-component="product-slider">
    <div class="flex w-full flex-col justify-center pb-2 border-b border-b-slate-200 mb-3 md:flex-row md:justify-between md:items-center">
      <div class="text-center md:text-left">
        <h2
          class="custom-format"
          style="
            --fs-desktop:16px;
            --fs-mobile:16px;

            --fw-desktop:600;
            --fw-mobile:600;

            --ls-desktop:0px;
            --ls-mobile:0px;
          "
        >
          {{ 'product.recomendations.also_like' | t }}
        </h2>
      </div>
    </div>

    <div data-product-slider class="swiper relative group w-full mt-3">
      <div class="swiper-wrapper">
        {% for collection in relatedLooks %}
          <div class="swiper-slide">
            <a
              class="group relative block overflow-hidden w-full"
              href="{{ collection.url }}"
            >
              <div class="absolute z-10	bottom-0 inset-x-0 w-full text-white p-2 bg-monastery-black/95 opacity-0 translate-y-1 duration-300 ease-in group-hover:opacity-100 group-hover:translate-y-0">
                <h2 class="text-xs tracking-wider md:text-sm lg:md:text-base">
                  {{ collection.title }}
                </h2>
              </div>

              <figure class="relative overflow-hidden aspect-[3/5]">
                {{
                  collection.featured_image
                  | image_url: width: '1200x1200'
                  | image_tag:
                    loading: 'lazy',
                    alt: collection.title,
                    class: 'block w-full h-full object-cover transition duration-1000 ease-in-out transform hover:scale-105 object-center'
                }}
              </figure>
            </a>
          </div>
        {% endfor %}
      </div>

      <button
        class="swiper-button-prev absolute top-1/3 left-1 z-10 bg-monastery-black p-1 md:opacity-0 group-hover:[&:not(.swiper-button-disabled)]:opacity-100 ease-in-out duration-150"
        aria-label="Go previous"
      >
        {% render 'chevron-left', classNames: 'w-5 h-5 text-white' %}
      </button>
      <button
        class="swiper-button-next absolute top-1/3 right-1 z-10 bg-monastery-black p-1 md:opacity-0 group-hover:[&:not(.swiper-button-disabled)]:opacity-100 ease-in-out duration-150"
        aria-label="Go next"
      >
        {% render 'chevron-right', classNames: 'w-5 h-5 text-white' %}
      </button>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Template page lookpage",
  "tag": "section"
}
{% endschema %}
