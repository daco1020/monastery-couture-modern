<div data-component="account" class="flex flex-col items-center justify-center h-full py-10 lg:py-20">
  <h1 class="block text-center font-bold text-lg mb-10 md:text-2xl lg:text-4xl">
    {{ 'account.form.reset_password' | t }}
  </h1>
  <div class="w-full max-w-md">
    <div>
      <div>
        {% form 'reset_customer_password' %}
          {% if form.errors %}
            <div class="mb-5">
              <div class="bg-rose-600 text-monastery-white p-3">
                <div class="flex items-center mb-5">
                  {% render 'error-icon' classNames: "w-10 h-10 mr-3" %}
                  <p>
                    {{ 'errors.form.error_form' | t }}
                  </p>
                </div>
                <ul class="list-disc list-inside">
                  {% for error in form.errors %}
                    <li>
                      {{ form.errors.messages[error] }}
                    </li>
                  {% endfor %}
                </ul>
              </div>
            </div>
          {% endif %}

          <div class="flex mb-3 last:mb-0">
            <div class="flex-1">
              <label for="password" class="block uppercase text-xs font-bold mb-1">
                {{ 'account.form.password' | t }}
              </label>
              <input
                type="password"
                name="customer[password]"
                id="password"
                autocomplete="current-password"
                class="block w-full border border-monastery-black p-2 text-sm placeholder:text-sm"
                required
              >
            </div>
          </div>

          <div class="flex mb-3 last:mb-0">
            <div class="flex-1">
              <label for="password_confirmation" class="block uppercase text-xs font-bold mb-1">
                {{ 'account.form.password_confirmation' | t }}
              </label>
              <input
                type="password"
                name="customer[password_confirmation]"
                id="password_confirmation"
                autocomplete="current-password"
                class="block w-full border border-monastery-black p-2 text-sm placeholder:text-sm"
                required
              >
            </div>
          </div>

          <div class="flex mb-3 last:mb-0">
            <div class="flex-1">
              <button type="submit" class="btn black grow text-base font-bold mt-3 w-full">
                <span> {{ 'account.form.password_submit' | t }} </span>
              </button>
            </div>
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Template password",
  "tag": "section",
  "class": "container"
}
{% endschema %}
