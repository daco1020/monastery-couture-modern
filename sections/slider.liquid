        },
        {
          "type": "range",
          "id": "button_opacity",
          "min": 0,
          "max": 1,
          "step": 0.1,
          "label": "Opacidad",
          "default": 1
        },
        {
          "type": "header",
          "content": "== Borde"
        },
        {
          "id": "button_border",
          "type": "radio",
          "label": "Borde del botón",
          "options": [
            {
              "value": "BLACK",
