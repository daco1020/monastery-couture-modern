<div class="container w-full py-5">
  {% paginate search.results by 8 %}
    <div>
      <h3 class="text-sm font-bold  mb-2 md:text-lg">
        {{ 'search.search' | t }}
      </h3>
      <form action="{{ routes.search_url }}">
        <div class="flex items-center border border-slate-300 rounded-3xl px-3">
          <label for="q">
            {% render 'search_icon', classNames: 'stroke-monastery-black h-6 w-6 transition-colors hover:stroke-slate-400' %}
          </label>
          <input
            class="grow bg-transparent p-3 focus:outline-none"
            type="search"
            name="q"
            id="q"
            placeholder="{{ "search.search_by_keywords" | t }}"
            autocomplete="off"
          >
        </div>
      </form>
    </div>

    {% if search.performed %}
      {% if search.results.size > 0 %}
        <p class="py-10">
          {{ 'search.results_to' | t }}
          <b>{{ search.terms }}</b>
        </p>

        <div class="flex justify-center flex-wrap w-full gap-3">
          {% for item in search.results %}
            {% case item.object_type %}
              {% when 'product' %}
                <div class="w-full md:w-[calc(50%_-_0.75rem)] lg:w-[calc(33.333%_-_0.75rem)] xl:w-[calc(25%_-_0.75rem)]">
                  {% render 'single-product', product: item %}
                </div>
              {% else %}

            {% endcase %}
          {% endfor %}
        </div>
      {% else %}
        <div class="flex justify-center py-10">
          <p class="text-base">
            {{ 'search.empty_results' | t }}
            <b>{{ search.terms }}</b>
          </p>
        </div>
      {% endif %}
    {% endif %}

    {% render 'pagination', pagination: paginate %}
  {% endpaginate %}
</div>
