{% if layout == 'small' %}
  <div class="grid grid-cols-4 w-full border-b border-white/5 py-6 items-center gap-4">
    <div class="col-span-1 aspect-square overflow-hidden rounded-sm bg-white/5">
      <a href="{{ item.url }}" class="block h-full w-full">
        {{
          item.product.featured_image
          | image_url: width: 200
          | image_tag: loading: 'lazy', alt: item.product.title, class: 'h-full w-full object-cover transition-transform duration-700 hover:scale-110'
        }}
      </a>
    </div>

    <div class="col-span-2">
      <div class="mb-3">
        <a class="block text-xs font-bold uppercase tracking-widest hover:text-gold transition-colors" href="{{ item.url }}">
          {{ item.product.title | truncate: 30 }}
        </a>
        {%- unless item.product.has_only_default_variant %}
          {%- for variant in item.options_with_values -%}
            <p class="text-[10px] opacity-60 mt-1">
              {{ variant.name }}: <span class="opacity-100 font-semibold">{{ variant.value }}</span>
            </p>
          {%- endfor -%}
        {% endunless %}
      </div>

      <div class="flex items-center space-x-1 border border-white/10 w-max px-1">
        <button
          type="button"
          class="p-1 opacity-60 hover:opacity-100 transition-opacity"
          onclick="window.$APP.Cart.handleUpdateItem({{ line }}, {{ item.quantity }} - 1)"
        >
          {% render 'minus-icon', classNames: 'w-3 h-3 text-white' %}
        </button>
        <input
          class="w-8 bg-transparent text-center text-xs font-bold focus:outline-none"
          type="number"
          name="updates[]"
          value="{{ item.quantity }}"
          min="1"
          max="{{ item.variant.inventory_quantity }}"
          id="updates_{{ line }}"
          oninput="if (this.value > {{ item.variant.inventory_quantity }}) this.value = {{ item.quantity }}; window.$APP.Cart.handleUpdateItem({{ line }}, this.value)"
        >
        <button
          class="p-1 opacity-60 hover:opacity-100 transition-opacity disabled:opacity-20"
          type="button"
          {% if item.variant.inventory_quantity == item.quantity %}disabled{% endif %}
          onclick="window.$APP.Cart.handleUpdateItem({{ line }}, {{ item.quantity }} + 1)"
        >
          {% render 'plus-icon', classNames: 'w-3 h-3 text-white' %}
        </button>
      </div>
    </div>

    <div class="col-span-1 text-right flex flex-col justify-between h-full py-1">
      <div class="pn-total-line-item font-bold text-xs" data-id="{{ item.key }}">{{ item.line_price | money }}</div>
      <button
        name="remove"
        type="button"
        class="text-[10px] uppercase tracking-widest opacity-40 hover:opacity-100 transition-opacity"
        onclick="window.$APP.Cart.handleUpdateItem({{ line }}, 0)"
      >
        {{ 'cart.general.remove' | t }}
      </button>
    </div>
  </div>
{% else %}
  <div class="grid grid-cols-3 w-full border-b-slate-300 border-b last:border-b-white/0 py-4 md:grid-cols-[200px_auto_20%] lg:py-8">
    <div class="col-span-1 md:w-52 md:h-52">
      <a class="aspect-square" href="{{ item.url }}">
        {{
          item.product.featured_image
          | image_url: width: '400x400'
          | image_tag: loading: 'lazy', alt: item.product.title, class: 'h-full w-full object-cover object-center'
        }}
      </a>
    </div>

    <div class="pl-2 col-span-2 md:col-span-1 md:pl-10">
      <div class="mb-2 md:mb-5">
        <a class="block text-sm font-bold  md:inline-block md:mr-1 md:text-base" href="{{ item.url }}">
          {{ item.product.title | truncatewords: 5, '...' }}
        </a>

        {%- unless item.product.has_only_default_variant %}
          {%- for variant in item.options_with_values -%}
            <p class="text-xs text-monastery-gray font-bold md:text-sm">
              {{ variant.name }}:
              <span class="font-medium"> {{ variant.value }}</span>
            </p>
          {%- endfor -%}
        {% endunless %}
      </div>

      <div class="mb-3 flex items-center">
        <button
          type="button"
          class="bg-monastery-black p-1"
          onclick="
            (function(){
                window.$APP.Cart.handleUpdateItem({{ line }}, {{ item.quantity }} - 1)
            })();
          "
        >
          {% render 'minus-icon', classNames: 'w-3 h-3 text-monastery-white' %}
        </button>
        <input
          class="w-10 mx-2 apparence-none-number text-center"
          type="number"
          name="updates[]"
          value="{{ item.quantity }}"
          min="1"
          max="{{ item.variant.inventory_quantity }}"
          id="updates_{{ line }}"
          oninput="
            (function(event){
                if (event.target.value > {{ item.variant.inventory_quantity }}) {
                    event.target.value = {{ item.quantity }}
                    return null;
                }
                window.$APP.Cart.handleUpdateItem({{ line }}, event.target.value)
            })(event);
          "
        >
        <button
          class="bg-monastery-black p-1 disabled:opacity-30"
          type="button"
          {% if item.variant.inventory_quantity == item.quantity %}
            disabled
          {% endif %}
          onclick="
            (function(){
                window.$APP.Cart.handleUpdateItem({{ line }}, {{ item.quantity }} + 1)
            })();
          "
        >
          {% render 'plus-icon', classNames: 'w-3 h-3 text-monastery-white' %}
        </button>
      </div>

      <div class="flex items-center">
        {% render 'delete-icon', classNames: 'w-5 h-5 text-monastery-black' %}
        <button
          name="remove"
          type="button"
          class="ml-1 text-monastery-black text-sm "
          onclick="
            (function(){
                window.$APP.Cart.handleUpdateItem({{ line }}, 0)
            })();
          "
        >
          {{ 'cart.general.remove' | t }}
        </button>
      </div>
    </div>

    <div class="mt-3 col-span-3 text-right md:col-span-1 md:mt-0">
      <p class="font-bold md:text-base">
        <div class="pn-total-line-item" data-id="{{ item.key }}">{{ item.line_price | money }}</div>
      </p>
    </div>
  </div>
{% endif %}
