<div
  class="custom-space w-full"
  style="--pt-desktop:{{ section.settings.desktop_offset_top }}px;--pb-desktop:{{ section.settings.desktop_offset_bottom }}px;--pt-mobile:{{ section.settings.mobile_offset_top }}px;--pb-mobile:{{ section.settings.mobile_offset_bottom }}px"
>
  {% if section.blocks.size > 0 %}
    <div class="flex justify-center flex-wrap w-full gap-2">
      {% for block in section.blocks %}
        {% if block.settings.look_collection != blank %}
          <a
            class="group relative block overflow-hidden w-[calc(50%_-_0.5rem)] lg:w-[calc(25%_-_0.5rem)]"
            href="{{ block.settings.look_collection.url }}"
          >
            <div class="absolute z-10	bottom-0 inset-x-0 w-full text-white p-2 bg-monastery-black/95 opacity-0 translate-y-1 duration-300 ease-in group-hover:opacity-100 group-hover:translate-y-0">
              <h2 class="text-xs tracking-wider md:text-sm lg:md:text-base">
                {{ block.settings.look_collection.title }}
              </h2>
            </div>

            <figure class="relative overflow-hidden aspect-[3/5]">
              {{
                block.settings.look_collection.featured_image
                | image_url: width: '1200x1200'
                | image_tag:
                  loading: 'lazy',
                  alt: block.settings.look_collection.title,
                  class: 'block w-full h-full object-cover transition duration-1000 ease-in-out transform hover:scale-105 object-center'
              }}
            </figure>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Template page looklist",
  "tag": "section",
  "class": "container",
  "settings": [
    {
      "type": "header",
      "content": "== Escritorio"
    },
    {
      "type": "number",
      "id": "desktop_offset_top",
      "label": "Espaciado superior",
      "default": 0
    },
    {
      "type": "number",
      "id": "desktop_offset_bottom",
      "label": "Espaciado inferior",
      "default": 0
    },
    {
      "type": "header",
      "content": "== Mobile"
    },
    {
      "type": "number",
      "id": "mobile_offset_top",
      "label": "Espaciado superior",
      "default": 0
    },
    {
      "type": "number",
      "id": "mobile_offset_bottom",
      "label": "Espaciado inferior",
      "default": 0
    }
  ],
  "blocks": [
    {
      "name": "Look",
      "type": "look_book",
      "settings": [
        {
          "type": "collection",
          "id": "look_collection",
          "label": "Colección"
        }
      ]
    }
  ]
}
{% endschema %}
