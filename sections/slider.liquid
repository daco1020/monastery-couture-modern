          "step": 1,
          "unit": "px",
          "label": "Grosor del borde",
          "default": 1
        },
        {
          "type": "header",
          "content": "= Botón en Escritorio"
        },
        {
          "type": "range",
          "id": "desktop_button_font_size",
          "min": 10,
          "max": 50,
          "step": 1,
          "unit": "px",
          "label": "Tamaño",
          "default": 16
        },
        {
          "type": "range",
          "id": "desktop_button_font_weight",
          "min": 100,
          "max": 900,
          "step": 100,
          "label": "Grosor",
          "default": 600
        },
        {
          "type": "range",
          "id": "desktop_button_letter_spacing",
          "min": 0,
          "max": 10,
          "step": 1,
          "unit": "px",
          "label": "Espacio entre letras",
          "default": 0
        },
        {
          "type": "header",
          "content": "= Botón en Mobile"
        },
        {
          "type": "range",
          "id": "mobile_button_font_size",
          "min": 10,
          "max": 50,
          "step": 1,
          "unit": "px",
          "label": "Tamaño",
          "default": 16
        },
        {
          "type": "range",
          "id": "mobile_button_font_weight",
          "min": 100,
          "max": 900,
          "step": 100,
          "label": "Grosor",
          "default": 600
        },
        {
          "type": "range",
          "id": "mobile_button_letter_spacing",
          "min": 0,
          "max": 10,
          "step": 1,
          "unit": "px",
          "label": "Espacio entre letras",
          "default": 0
        },
        {
          "type": "header",
          "content": "== Configuracion"
        },
        {
          "id": "pagination_color",
          "type": "radio",
          "label": "Color de la paginación",
          "options": [
            {
              "value": "BLACK",
              "label": "Negro"
            },
            {
              "value": "WHITE",
              "label": "Blanco"
            }
          ],
          "default": "BLACK"
        },
        {
          "type": "number",
          "id": "delay",
          "label": "Autoplay",
          "default": 5000,
          "info": "Duración del slide en milisegundos"
        },
        {
          "id": "overlay",
          "type": "range",
          "min": 0,
          "max": 1,
          "step": 0.1,
          "label": "Overlay opacity",
          "default": 0
        },
        {
          "type": "header",
          "content": "== Escritorio"
        },
        {
          "type": "select",
          "id": "desktop_vertical_alignment",
          "label": "Alineación del contenido (Vertical)",
          "options": [
            {
              "value": "lg:top-0 lg:-translate-y-0 lg:bottom-[initial]",
              "label": "Superior"
            },
            {
              "value": "lg:top-1/2 lg:-translate-y-1/2 lg:bottom-[initial]",
              "label": "Centro"
            },
            {
              "value": "lg:bottom-0 lg:-translate-y-0 lg:top-[initial]",
              "label": "Inferior"
            }
          ],
          "default": "lg:bottom-0 lg:-translate-y-0 lg:top-[initial]"
        },
        {
          "type": "select",
          "id": "desktop_horizontal_alignment",
          "label": "Alineación del contenido (Horizontal)",
          "options": [
            {
              "value": "lg:left-0 lg:-translate-x-0 lg:right-[initial]",
              "label": "Izquierda"
            },
            {
              "value": "lg:left-1/2 lg:-translate-x-1/2 lg:right-[initial]",
              "label": "Centro"
            },
            {
              "value": "lg:right-0 lg:-translate-x-0 lg:left-[initial]",
              "label": "Derecha"
            }
          ],
          "default": "lg:left-0 lg:-translate-x-0 lg:right-[initial]"
        },
        {
          "type": "select",
          "id": "desktop_text_alignment",
          "label": "Alineación del texto",
          "options": [
            {
              "value": "lg:text-left",
              "label": "Izquierda"
            },
            {
              "value": "lg:text-center",
              "label": "Centro"
            },
            {
              "value": "lg:text-right",
              "label": "Derecha"
            }
          ],
          "default": "lg:text-left"
        },
        {
          "type": "number",
          "id": "desktop_offset_top",
          "label": "Espaciado superior",
          "default": 0
        },
        {
          "type": "number",
          "id": "desktop_offset_bottom",
          "label": "Espaciado inferior",
          "default": 0
        },
        {
