<div
  data-component="product-slider"
  class="custom-space relative w-full md:flex md:flex-wrap"
  style="--pt-desktop:{{ section.settings.desktop_offset_top }}px;--pb-desktop:{{ section.settings.desktop_offset_bottom }}px;--pt-mobile:{{ section.settings.mobile_offset_top }}px;--pb-mobile:{{ section.settings.mobile_offset_bottom }}px"
>
  {% if section.blocks.size > 0 %}
    <div class="flex w-full flex-col justify-center pb-2 border-b border-b-slate-200 md:flex-row md:justify-between md:items-center">
      <div class="text-center md:text-left">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'custom_text_title' %}
              <h2
                class="custom-format"
                style="
                  --fs-desktop: {{- block.settings.desktop_font_size -}}px;
                  --fs-mobile: {{- block.settings.mobile_font_size -}}px;

                  --fw-desktop: {{- block.settings.desktop_font_weight -}};
                  --fw-mobile: {{- block.settings.mobile_font_weight -}};

                  --ls-desktop: {{- block.settings.desktop_letter_spacing -}}px;
                  --ls-mobile: {{- block.settings.mobile_letter_spacing -}}px;
                "
              >
                {{ block.settings.title }}
              </h2>
            {% when 'custom_sub_title' %}
              <div
                class="custom-format text-monastery-gray"
                style="
                  --fs-desktop: {{- block.settings.desktop_font_size -}}px;
                  --fs-mobile: {{- block.settings.mobile_font_size -}}px;

                  --fw-desktop: {{- block.settings.desktop_font_weight -}};
                  --fw-mobile: {{- block.settings.mobile_font_weight -}};

                  --ls-desktop: {{- block.settings.desktop_letter_spacing -}}px;
                  --ls-mobile: {{- block.settings.mobile_letter_spacing -}}px;
                "
              >
                {{ block.settings.content }}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
      <div class="text-center leading-none md:text-right">
        {% for block in section.blocks %}
          {% if block.type == 'button_link' %}
            {% unless block.settings.link == blank %}
              <a
                href="{{ block.settings.link }}"
                class="btn black mt-2 custom-format"
                style="
                  --fs-desktop: {{- block.settings.desktop_font_size -}}px;
                  --fs-mobile: {{- block.settings.mobile_font_size -}}px;

                  --fw-desktop: {{- block.settings.desktop_font_weight -}};
                  --fw-mobile: {{- block.settings.mobile_font_weight -}};

                  --ls-desktop: {{- block.settings.desktop_letter_spacing -}}px;
                  --ls-mobile: {{- block.settings.mobile_letter_spacing -}}px;
                "
                {% if block.settings.is_blank %}
                  target="_blank"
                  rel="noopener noreferrer"
                {% endif %}
              >
                <span>{{ block.settings.label }}</span>
              </a>
            {% endunless %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if section.settings.product_list.count > 0 %}
    <!-- Slider main container -->
    <div data-product-slider class="swiper relative group w-full mt-3">
      <!-- Additional required wrapper -->
      <div class="swiper-wrapper">
        <!-- Slides -->
        {% liquid
          assign product_source = section.settings.product_list
          if section.settings.collection != blank and product_source.count == 0
            assign product_source = section.settings.collection.products
          endif
        %}
        {%- for product in product_source -%}
          {%- if product != blank -%}
            <div class="swiper-slide">
              {% render 'single-product', product: product, layout: 'slide' %}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <button
        class="swiper-button-prev absolute top-1/3 left-1 z-10 bg-monastery-black p-1 md:opacity-0 group-hover:[&:not(.swiper-button-disabled)]:opacity-100 ease-in-out duration-150"
        aria-label="Go previous"
      >
        {% render 'chevron-left', classNames: 'w-5 h-5 text-white' %}
      </button>
      <button
        class="swiper-button-next absolute top-1/3 right-1 z-10 bg-monastery-black p-1 md:opacity-0 group-hover:[&:not(.swiper-button-disabled)]:opacity-100 ease-in-out duration-150"
        aria-label="Go next"
      >
        {% render 'chevron-right', classNames: 'w-5 h-5 text-white' %}
      </button>
    </div>
  {% endif %}
</div>

